{
  "name": "@tencentdb-agent-memory/tdai-memory-agent-sdk",
  "version": "0.1.0",
  "description": "TypeScript adapter for using TencentDB Agent Memory with Codex SDK and Claude Code Agent SDK.",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "files": [
    "dist/",
    "src/",
    "examples/",
    "README.md"
  ],
  "engines": {
    "node": ">=22.16.0"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": "*",
    "@openai/codex-sdk": "*"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@openai/codex-sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
