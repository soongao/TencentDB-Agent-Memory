# Source this file from the repository root.
TDAI_GATEWAY_CONFIG=./packages/tdai-memory-mcp/examples/tdai-gateway-ollama.yaml
TDAI_GATEWAY_URL=http://127.0.0.1:8420
TDAI_GATEWAY_API_KEY=

# Optional default session for MCP/E2E tests.
TDAI_SESSION_KEY=agent:mcp-ollama:e2e
TDAI_USER_ID=local-ollama

# MCP-side Gateway supervisor.
TDAI_GATEWAY_AUTO_START=1
TDAI_GATEWAY_CWD=/Users/bytedance/proj/TencentDB-Agent-Memory
TDAI_GATEWAY_STARTUP_TIMEOUT_MS=30000
TDAI_GATEWAY_HEALTH_POLL_MS=500
